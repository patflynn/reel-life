# reel-life configuration
# Secrets should be set via environment variables, not in this file.

sonarr:
  base_url: http://sonarr:8989
  # api_key: set SONARR_API_KEY env var

chat:
  backend: googlechat
  # webhook_url: set GOOGLE_CHAT_WEBHOOK_URL env var

  # Telegram backend (set backend: telegram to use)
  # telegram_chat_id: 0          # 0 = auto-capture from first message
  # telegram_allowed_users: []   # list of Telegram user IDs allowed to interact
  # bot token: set TELEGRAM_BOT_TOKEN env var

agent:
  model: claude-sonnet-4-5-20250929
  max_tokens: 4096

monitor:
  enabled: true
  interval: 5m

log:
  level: info    # debug, info, warn, error
  format: text   # text or json

server:
  port: 9090     # HTTP port for health checks and webhooks
